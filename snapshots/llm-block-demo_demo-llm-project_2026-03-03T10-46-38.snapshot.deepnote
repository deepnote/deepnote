          type: code
          content: >-
            import statistics


            # Compute statistics

            mean = statistics.mean(data)

            median = statistics.median(data)

            minimum = min(data)

            maximum = max(data)

            std_dev = statistics.stdev(data)


            # Print the results

            statistics_summary = f"Statistics:\n- Mean: {mean:.2f}\n- Median: {median}\n- Min: {minimum}\n- Max:
