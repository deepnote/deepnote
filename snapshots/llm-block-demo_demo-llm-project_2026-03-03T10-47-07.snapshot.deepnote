          type: code
          content: >-
            import numpy as np


            # Compute basic statistics

            mean = np.mean(data)

            median = np.median(data)

            minimum = np.min(data)

            maximum = np.max(data)

            std_dev = np.std(data)


            # Formatted output

            stats = f"Basic Statistics:\n- Mean: {mean:.2f}\n- Median: {median:.2f}\n- Min: {minimum}\n- Max:
