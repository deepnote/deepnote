          contentHash: sha256:f9fc9cbedfe948a584311f86922276bbce791d383ee3877832833be70397c621
          executionCount: null
          outputs: []
          type: code
          content: >-
            import numpy as np


            # Compute basic statistics

            mean = np.mean(data)

            median = np.median(data)

            min_value = np.min(data)

            max_value = np.max(data)

            std_dev = np.std(data)


            # Print the statistics in a formatted way

            stats = f"Statistics:\n" +
                   f"Mean: {mean:.2f}\n" +
                   f"Median: {median:.2f}\n" +
                   f"Min: {min_value}\n" +
                   f"Max: {max_value}\n" +
                   f"Std Dev: {std_dev:.2f}" 

            print(stats)
          metadata: {}
